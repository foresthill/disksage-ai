}

# Parse the Claude API response. Extracts the structured judgments and writes
# them as a TSV (index \t recommendation \t confidence \t reasoning) to $2.
# Returns non-zero on API error, refusal, or malformed output.
parse_ai_response() {
  local response_file="$1"
  local out_tsv="$2"
  RESPONSE_FILE="$response_file" OUT_TSV="$out_tsv" python3 <<'PYEOF'
import os, json, sys

resp_file = os.environ["RESPONSE_FILE"]
out_tsv = os.environ["OUT_TSV"]

try:
    with open(resp_file) as f:
        data = json.load(f)
except Exception as e:
    sys.stderr.write("AI response was not valid JSON: %s\n" % e)
    sys.exit(2)

if isinstance(data, dict) and data.get("type") == "error":
    err = data.get("error", {}) or {}
    sys.stderr.write("API error: %s: %s\n" % (err.get("type", "?"), err.get("message", "?")))
    sys.exit(3)

if data.get("stop_reason") == "refusal":
    sys.stderr.write("The model declined to analyze these findings.\n")
    sys.exit(4)

text = None
for block in data.get("content", []) or []:
    if block.get("type") == "text":
        text = block.get("text")
        break
if not text:
    sys.stderr.write("AI response contained no text block.\n")
    sys.exit(5)

try:
    payload = json.loads(text)
except Exception as e:
    sys.stderr.write("AI structured output was not valid JSON: %s\n" % e)
    sys.exit(6)

def clean(s):
    return str(s).replace("\t", " ").replace("\n", " ").strip()

with open(out_tsv, "w") as w:
    for j in payload.get("judgments", []) or []:
        w.write("\t".join([
            str(j.get("index", "")),
            clean(j.get("recommendation", "")),
            clean(j.get("confidence", "")),
            clean(j.get("reasoning", "")),
        ]) + "\n")

usage = data.get("usage", {}) or {}
sys.stderr.write("tokens: input=%s output=%s\n" % (
    usage.get("input_tokens", "?"), usage.get("output_tokens", "?")))
PYEOF
}

# Show the exact metadata that would be sent, then ask for confirmation.
# Returns 0 to proceed, non-zero to abort.
ai_preview_and_confirm() {
  local findings_file="$1"
  local assume_yes="$2"
  local total
  total=$(grep -c . "$findings_file" 2>/dev/null || true)
  [[ -z "$total" ]] && total=0

  {
    echo
    echo "${C_BOLD}AI analysis — privacy review${C_RESET}"
    echo "DiskSage will send the ${C_BOLD}exact metadata below${C_RESET} to the API —"
    echo "nothing more. Paths are ${C_BOLD}masked${C_RESET} (username and your own folder"
    echo "names removed); ${C_BOLD}file contents are never read or transmitted.${C_RESET}"
    echo
    echo "  Provider: $AI_PROVIDER"
    echo "  Endpoint: $AI_URL"
    echo "  Model:    $AI_MODEL_RESOLVED"
    echo "  Items:    $total finding(s)"
    echo
  } >&2

  # $findings_file here is already the masked file — show paths verbatim.
  while IFS=$'\t' read -r _sev _pid path size desc _action; do
    printf '  %s- %-10s%s %s\n' "$C_DIM" "$(human_size "$size")" "$C_RESET" "$path" >&2
    printf '      %s%s%s\n' "$C_DIM" "$desc" "$C_RESET" >&2
  done < "$findings_file"
  echo >&2

  if [[ "$assume_yes" == "true" ]]; then
    info "Proceeding (--yes given)."
    return 0
  fi
  if [[ ! -r /dev/tty ]]; then
    warn "Not an interactive terminal; re-run with --yes to allow sending. Skipping AI analysis."
    return 1
  fi

  local reply=""
  printf '%sSend this metadata to Claude? [y/N]%s ' "$C_BOLD" "$C_RESET" >&2
  read -r reply < /dev/tty || reply=""
  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *) info "Aborted — nothing was sent."; return 1 ;;
  esac
}

# Orchestrate AI analysis: preflight → confirm → request → parse.
# Writes judgments TSV to $2. Returns 0 on success.
run_ai_analysis() {
  local findings_file="$1"
  local ai_out="$2"
  local assume_yes="$3"

  command -v curl    >/dev/null 2>&1 || { warn "--ai needs 'curl' (not found in PATH). Skipping AI analysis."; return 1; }
  command -v python3 >/dev/null 2>&1 || { warn "--ai needs python3. Skipping AI analysis.";                  return 1; }
  if ! ai_resolve; then
    warn "--ai needs an API key (bring your own key). Set one of:"
    warn "  export ANTHROPIC_API_KEY=sk-ant-...      (Anthropic direct — https://console.anthropic.com/)"
    warn "  export OPENROUTER_API_KEY=sk-or-...      (OpenRouter — https://openrouter.ai/keys)"
    return 1
  fi
  if [[ ! -s "$findings_file" ]]; then
    info "No findings to analyze — skipping AI analysis."
    return 1
  fi

  # Mask paths BEFORE anything is shown or sent. The preview and the request
  # body are both built from this masked file, so what you confirm is exactly
  # what leaves the machine.
  local masked_file
  masked_file=$(mktemp)
  if ! ai_mask_findings "$findings_file" > "$masked_file"; then
    warn "Failed to prepare (mask) findings for AI. Skipping AI analysis."
    rm -f "$masked_file"
    return 1
  fi

  ai_preview_and_confirm "$masked_file" "$assume_yes" || { rm -f "$masked_file"; return 1; }

  info "Asking Claude for contextual judgment… (provider: $AI_PROVIDER, model: $AI_MODEL_RESOLVED)"
  local req_file resp_file curl_err http_code rc=1
  req_file=$(mktemp); resp_file=$(mktemp); curl_err=$(mktemp)

  # Build curl args as one always-non-empty array. (Separate empty arrays would
  # trip "unbound variable" under `set -u` on macOS's bash 3.2.) Auth header
  # differs by provider; anthropic-version is sent only for Anthropic direct.
  local -a curl_args
  curl_args=(-sS -o "$resp_file" -w '%{http_code}'
             -X POST "$AI_URL"
             -H "Content-Type: application/json")
  if [[ "$AI_AUTH" == "bearer" ]]; then
    curl_args+=(-H "Authorization: Bearer $AI_KEY")
  else
    curl_args+=(-H "x-api-key: $AI_KEY")
  fi
  [[ -n "$AI_VERSION_HDR" ]] && curl_args+=(-H "anthropic-version: $AI_VERSION_HDR")
  curl_args+=(--data @"$req_file")

  if ! build_ai_request "$masked_file" "$AI_MODEL_RESOLVED" > "$req_file"; then
    warn "Failed to build the AI request payload."
  elif ! http_code=$(curl "${curl_args[@]}" 2>"$curl_err"); then
    warn "Network error contacting the API ($AI_URL):"
    warn "  $(tr '\n' ' ' < "$curl_err")"
  else
    [[ "$http_code" == 2* ]] || warn "API returned HTTP $http_code (provider: $AI_PROVIDER)."
    if parse_ai_response "$resp_file" "$ai_out"; then
      info "AI analysis complete."
      rc=0
    else
      warn "Could not use the API response (HTTP $http_code) — skipping AI section."
    fi
  fi

  # Optional audit log: save exactly what was sent / received, plus a
  # real→masked mapping so you can verify masking. Enabled by DISKSAGE_AI_LOG.
  # NOTE: masking.tsv contains REAL paths — local audit only, never shared.
  if [[ -n "${DISKSAGE_AI_LOG:-}" && -s "$req_file" ]]; then
    local logdir
    logdir="$DISKSAGE_HOME/ai-logs/$(filename_now)"
    mkdir -p "$logdir"
    cp "$req_file"  "$logdir/request.json"  2>/dev/null
    cp "$resp_file" "$logdir/response.json" 2>/dev/null
    write_masking_log "$findings_file" "$masked_file" > "$logdir/masking.tsv" 2>/dev/null
    info "AI audit log: $(tildify "$logdir")"
  fi

  rm -f "$req_file" "$resp_file" "$curl_err" "$masked_file"
  return $rc
}

# Write a real→masked audit table (TSV) for the current findings, so masking
# effectiveness can be inspected. Reads the real and masked findings files
# (same line order → same index). Prints to stdout.
write_masking_log() {
  local real="$1" masked="$2"
  REAL="$real" MASKED="$masked" python3 <<'PYEOF'
import os, sys

def load(p):
    rows = []
    try:
        with open(p) as f:
            for line in f:
                line = line.rstrip("\n")
                if not line:
                    continue
                c = line.split("\t")
                if len(c) >= 6:
                    rows.append(c)
    except OSError:
        pass
    return rows

R = load(os.environ["REAL"])
M = load(os.environ["MASKED"])
n = min(len(R), len(M))
print("index\tpattern_id\treal_path\tmasked_path\tanonymized")
changed = 0
for i in range(n):
    rp, mp = R[i][2], M[i][2]
    a = "yes" if rp != mp else "no"
    if a == "yes":
        changed += 1
    print("%d\t%s\t%s\t%s\t%s" % (i, R[i][1], rp, mp, a))
sys.stderr.write("masking: %d/%d paths anonymized\n" % (changed, n))
PYEOF
}

# Render the AI Assessment section by joining findings with AI judgments.
render_ai_section() {
  local findings_file="$1"
  local ai_file="$2"
  local model="$3"
  [[ -s "$ai_file" ]] || return 0
  FINDINGS_FILE="$findings_file" AI_FILE="$ai_file" HOMEDIR="$HOME" MODEL="$model" \
  LANG_CODE="$DS_LANG" python3 <<'PYEOF'
import os

findings_file = os.environ["FINDINGS_FILE"]
ai_file = os.environ["AI_FILE"]
home = os.environ["HOMEDIR"]
model = os.environ["MODEL"]
lang = os.environ.get("LANG_CODE", "en")
ja = (lang == "ja")

def human(n):
    units = ("B", "KB", "MB", "GB", "TB", "PB")
    i = 0
    n = float(n)
    while n >= 1024 and i < len(units) - 1:
        n /= 1024
        i += 1
    return ("%d %s" % (int(n), units[i])) if i == 0 else ("%.1f %s" % (n, units[i]))

def tildify(p):
    if p == home:
        return "~"
    if p.startswith(home + "/"):
        return "~" + p[len(home):]
    return p

findings = {}
with open(findings_file) as f:
    for i, line in enumerate(f):
        line = line.rstrip("\n")
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 6:
            continue
        findings[i] = {"path": parts[2], "size": parts[3], "desc": parts[4]}

judg = {}
with open(ai_file) as f:
    for line in f:
        line = line.rstrip("\n")
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        try:
            idx = int(parts[0])
        except ValueError:
            continue
        judg[idx] = {"rec": parts[1], "conf": parts[2], "reason": parts[3]}

emoji = {"safe_to_delete": "🟢", "archive_then_delete": "🟡",
         "review_first": "🟠", "keep": "🔴"}
if ja:
    label = {"safe_to_delete": "削除して安全", "archive_then_delete": "退避してから削除",
             "review_first": "要確認", "keep": "保持"}
    conf = {"high": "高", "medium": "中", "low": "低"}
    hdr = "## 🤖 AI 判定"
    disclaimer = ("_Claude（`%s`）による文脈判定。**マスク済みメタデータのみ**送信しました"
                  "（パスは匿名化・ファイル内容は非送信）。下記のパスは実際のローカルパスで、"
                  "あなただけが確認できます。提案のみ、判断はあなたです。_" % model)
    none_msg = "_AI の判定は返りませんでした。_"
    lbl_path, lbl_size, lbl_reason, conf_word = "パス", "サイズ", "AI の判定理由", "確信度"
else:
    label = {"safe_to_delete": "Safe to delete", "archive_then_delete": "Archive, then delete",
             "review_first": "Review first", "keep": "Keep"}
    conf = {"high": "high", "medium": "medium", "low": "low"}
    hdr = "## 🤖 AI Assessment"
    disclaimer = ("_Contextual judgment from Claude (`%s`). **Masked metadata only** was sent "
                  "(paths anonymized; file contents never transmitted). Paths below are the "
                  "real local paths — for your eyes only. Suggestions only; you decide._" % model)
    none_msg = "_No AI judgments were returned._"
    lbl_path, lbl_size, lbl_reason, conf_word = "Path", "Size", "AI reasoning", "confidence"
order = ["keep", "review_first", "archive_then_delete", "safe_to_delete"]

items = [(i, findings[i], judg[i]) for i in findings if i in judg]

def sort_key(t):
    _i, fi, ju = t
    try:
        r = order.index(ju["rec"])
    except ValueError:
        r = 99
    try:
        s = int(fi["size"])
    except ValueError:
        s = 0
    return (r, -s)

items.sort(key=sort_key)

print()
print(hdr)
print()
print(disclaimer)

if not items:
    print()
    print(none_msg)
else:
    for _i, fi, ju in items:
        rec = ju["rec"]
        e = emoji.get(rec, "•")
        lbl = label.get(rec, rec)
        cf = conf.get(ju["conf"], ju["conf"])
        print()
        if ja:
            print("- %s **%s**（%s: %s）— %s" % (e, lbl, conf_word, cf, fi["desc"]))
        else:
            print("- %s **%s** (%s %s) — %s" % (e, lbl, cf, conf_word, fi["desc"]))
        if fi["path"] and fi["path"] != "/":
            print("  - %s: `%s`" % (lbl_path, tildify(fi["path"])))
        try:
            if int(fi["size"]) > 0:
                print("  - %s: %s" % (lbl_size, human(fi["size"])))
        except ValueError:
            pass
        print("  - %s: %s" % (lbl_reason, ju["reason"]))
PYEOF
}

