main() {
  local cmd="${1:-help}"
  (( $# > 0 )) && shift
  case "$cmd" in
    scan)                  cmd_scan "$@" ;;
    serve)                 cmd_serve "$@" ;;
    snapshot)              cmd_snapshot "$@" ;;
    trend)                 cmd_trend "$@" ;;
    version|--version|-v)  cmd_version ;;
    help|--help|-h)        cmd_help "$@" ;;
    *)                     die "unknown command: $cmd  (try: disksage help)" ;;
  esac
}

main "$@"
