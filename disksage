def page():
    f = newest("*.html")
    if not f:
        return ("<!doctype html><meta charset=utf-8>"
                "<body style='font-family:sans-serif;padding:40px'>"
                + TOOLBAR + "<p>" + empty_msg + "</p></body>").encode("utf-8")
    with open(f, encoding="utf-8") as h:
        doc = h.read()
    marker = "<div class='wrap'>"
    if marker in doc:
        doc = doc.replace(marker, marker + TOOLBAR + delete_panel(), 1)
    return doc.encode("utf-8")

class Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code, body=b"", ctype="text/html; charset=utf-8", headers=None):
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        for k, v in (headers or {}).items():
            self.send_header(k, v)
        self.end_headers()
        if body:
            self.wfile.write(body)

    def do_GET(self):
        path = urllib.parse.urlparse(self.path).path
        if path in ("/", "/index.html"):
            self._send(200, page())
        elif path == "/favicon.ico":
            self._send(204)
        else:
            self._send(404, b"not found")

    def do_POST(self):
        path = urllib.parse.urlparse(self.path).path
        if path == "/rescan":
            subprocess.run([self_bin, *scan_flags], env=scan_env, check=False)
            self._send(303, b"", headers={"Location": "/"})
        elif path == "/delete":
            length = int(self.headers.get("Content-Length", "0") or "0")
            body = self.rfile.read(length).decode("utf-8") if length else ""
            requested = urllib.parse.parse_qs(body).get("del", [])
            # Validate every requested path against the current whitelist —
            # the server only ever trashes paths it is currently offering.
            allowed = {fi["path"] for fi in deletable()}
            valid = [p for p in requested if p in allowed]
            if valid:
                to_trash(valid)
            subprocess.run([self_bin, *scan_flags], env=scan_env, check=False)
            self._send(303, b"", headers={"Location": "/"})
        else:
            self._send(404, b"not found")

    def log_message(self, *_a):
        pass  # keep the terminal quiet

class Server(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True

httpd = Server(("127.0.0.1", port), Handler)
threading.Timer(0.6, lambda: webbrowser.open("http://127.0.0.1:%d/" % port)).start()
try:
    httpd.serve_forever()
except KeyboardInterrupt:
    pass
finally:
    httpd.server_close()
PYEOF
}

cmd_snapshot() {
  ensure_dirs
  local now_iso filename df_out
  now_iso=$(iso_now)
  filename="$TRENDS_DIR/$(filename_now).json"
  df_out=$(df -Pk 2>/dev/null | awk 'NR>1')

  DF_OUT="$df_out" NOW_ISO="$now_iso" OUT_PATH="$filename" python3 <<'PYEOF'
import os, json

df_out = os.environ["DF_OUT"]
now_iso = os.environ["NOW_ISO"]
out_path = os.environ["OUT_PATH"]

volumes = []
for line in df_out.splitlines():
    parts = line.split()
    if len(parts) < 6:
        continue
    fs = parts[0]
    try:
        size_kb = int(parts[1]); used_kb = int(parts[2]); avail_kb = int(parts[3])
    except ValueError:
        continue
    if not fs.startswith("/dev/"):
        continue
    volumes.append({
        "filesystem": fs,
        "mount": " ".join(parts[5:]),
        "size_bytes": size_kb * 1024,
        "used_bytes": used_kb * 1024,
        "avail_bytes": avail_kb * 1024,
        "capacity": parts[4],
    })

with open(out_path, "w") as w:
    json.dump({"timestamp": now_iso, "volumes": volumes}, w, indent=2)
PYEOF

  info "Snapshot written: $(tildify "$filename")"
}

cmd_trend() {
  ensure_dirs
  local count
  count=$(find "$TRENDS_DIR" -maxdepth 1 -name '*.json' 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$count" == "0" ]]; then
    warn "No snapshots yet. Run 'disksage snapshot' first (or set a cron job)."
    return 1
  fi
  info "$count snapshot(s) in $(tildify "$TRENDS_DIR")"

  TRENDS_DIR="$TRENDS_DIR" python3 <<'PYEOF'
import os, json, glob
from collections import defaultdict

trends_dir = os.environ["TRENDS_DIR"]
files = sorted(glob.glob(os.path.join(trends_dir, "*.json")))

def human(n):
    units = ("B", "KB", "MB", "GB", "TB", "PB")
    i = 0
    while n >= 1024 and i < len(units) - 1:
        n /= 1024
        i += 1
    return f"{int(n)} {units[i]}" if i == 0 else f"{n:.1f} {units[i]}"

by_fs = defaultdict(list)
for f in files:
    try:
        with open(f) as r:
            d = json.load(r)
    except Exception:
        continue
    ts = d.get("timestamp", "")
    for v in d.get("volumes", []):
        key = (v.get("filesystem", ""), v.get("mount", ""))
        by_fs[key].append((
            ts,
            v.get("size_bytes", 0),
            v.get("used_bytes", 0),
            v.get("avail_bytes", 0),
        ))

for (fs, mount), series in sorted(by_fs.items()):
    print(f"\n=== {fs}  ({mount}) ===")
    print(f"{'Timestamp':<20}  {'Used':>10}  {'Avail':>10}  {'Capacity':>9}")
    print("-" * 56)
    for ts, sz, used, avail in series:
        cap = (used / sz * 100) if sz else 0.0
        print(f"{ts:<20}  {human(used):>10}  {human(avail):>10}  {cap:>8.1f}%")
    if len(series) > 1:
        delta = series[-1][2] - series[0][2]
        sign = "+" if delta >= 0 else "-"
        print(f"\nΔ used: {sign}{human(abs(delta))} over {len(series)} snapshots")
PYEOF
}

