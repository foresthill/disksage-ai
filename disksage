  C_RED="";   C_YELLOW=""; C_GREEN=""; C_CYAN=""
fi

# ───────────────────────────────────────────────────────────────
# Logging + small helpers
# ───────────────────────────────────────────────────────────────

info() { printf '%s[disksage]%s %s%s%s\n' "$C_DIM" "$C_RESET" "$C_CYAN" "$*" "$C_RESET" >&2; }
warn() { printf '%s[disksage]%s %s%s%s\n' "$C_DIM" "$C_RESET" "$C_YELLOW" "$*" "$C_RESET" >&2; }
die()  { printf '%s[disksage]%s %sERROR:%s %s\n' "$C_DIM" "$C_RESET" "$C_RED" "$C_RESET" "$*" >&2; exit 1; }

ensure_dirs() { mkdir -p "$SCANS_DIR" "$TRENDS_DIR"; }

iso_now()      { date '+%Y-%m-%dT%H:%M:%S'; }
filename_now() { date '+%Y-%m-%d_%H%M%S'; }

# Human-readable byte formatter (pure awk, no dependencies)
human_size() {
  local bytes="${1:-0}"
  [[ -z "$bytes" ]] && bytes=0
  awk -v b="$bytes" 'BEGIN {
    split("B KB MB GB TB PB", u, " ")
    i = 1
    while (b >= 1024 && i < 6) { b = b / 1024; i++ }
    if (i == 1) printf "%d %s", b, u[i]
    else        printf "%.1f %s", b, u[i]
  }'
}

file_size_bytes() {
  local path="$1"
  [[ -f "$path" ]] || { echo 0; return; }
  if [[ "$OS" == "Darwin" ]]; then
    stat -f%z "$path" 2>/dev/null || echo 0
  else
    stat -c%s "$path" 2>/dev/null || echo 0
  fi
}

dir_size_bytes() {
  local path="$1"
  [[ -e "$path" ]] || { echo 0; return; }
  local kb
  kb=$(du -sk "$path" 2>/dev/null | awk '{print $1}')
  [[ -z "$kb" ]] && kb=0
  echo $(( kb * 1024 ))
}

# Collapse $HOME to ~ for readable output
tildify() {
  local path="$1"
  if [[ "$path" == "$HOME" ]]; then echo "~"
  elif [[ "$path" == "$HOME"/* ]]; then echo "~${path#$HOME}"
  else echo "$path"
  fi
}

# ───────────────────────────────────────────────────────────────
# Findings file: tab-separated
#   severity \t pattern_id \t path \t size_bytes \t description \t action
# ───────────────────────────────────────────────────────────────

add_finding() {
  local findings_file="$1"
  local pattern_id="$2"
  local path="$3"
  local size_bytes="$4"
  local severity="$5"
  local description="$6"
  local action="$7"
  description="${description//$'\t'/ }"; description="${description//$'\n'/ }"
  action="${action//$'\t'/ }";           action="${action//$'\n'/ }"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$severity" "$pattern_id" "$path" "$size_bytes" "$description" "$action" \
    >> "$findings_file"
}

