cmd_scan() {
  ensure_dirs
  resolve_lang   # set DS_LANG for the localized report (from DISKSAGE_LANG/$LANG)
  local use_ai=false
  local quick=false
  local assume_yes=false
  local want_html=false
  while (( $# > 0 )); do
    case "$1" in
      --ai)           use_ai=true ;;
      --quick)        quick=true ;;
      -y|--yes)       assume_yes=true ;;
      --html)         want_html=true ;;
      --ai-log)       export DISKSAGE_AI_LOG=1 ;;
      -h|--help)      cmd_help scan; return 0 ;;
      *)              warn "scan: ignoring unknown argument '$1'" ;;
    esac
    shift
  done

  if ! $quick; then
    # Pre-scan banner about TCC (Full Disk Access) behavior. The flow-type
    # pass walks $HOME including protected paths (Messages, Photos, Mail, …)
    # so macOS may show permission dialogs. Users who want a quiet scan can
    # opt out with --quick.
    cat >&2 <<EOF

${C_BOLD}Heads-up:${C_RESET} this scan includes a flow-type pass that walks your home
directory for large files modified in the last 30 days. macOS may show
permission dialogs for protected apps (Photos, Messages, Mail, Calendar…).

  ${C_GREEN}Allow${C_RESET}   DiskSage reads ${C_BOLD}size + modification time only${C_RESET} (never contents).
  ${C_YELLOW}Deny${C_RESET}    those files just won't appear in the flow-type report.
  ${C_CYAN}Skip${C_RESET}    run ${C_BOLD}disksage scan --quick${C_RESET} to omit the flow-type pass entirely.

EOF
  fi

  if $quick; then
    info "Scanning known hot spots… (quick mode: flow-type pass skipped)"
  else
    info "Scanning known hot spots… (this may take a minute; find can print permission warnings)"
  fi

  local findings_file ai_file
  findings_file=$(mktemp)
  ai_file=$(mktemp)
  # Expand paths NOW (double quotes) — these are local, so deferred
  # single-quote expansion would trip `set -u` after cmd_scan returns.
  # shellcheck disable=SC2064
  trap "rm -f '$findings_file' '$ai_file'" EXIT

  check_apfs_snapshots          "$findings_file"
  check_iphone_backup           "$findings_file"
  check_docker_raw              "$findings_file"
  check_ollama_models           "$findings_file"
  check_node_modules_aggregate  "$findings_file"
  check_vm_swap                 "$findings_file"
  check_electron_cache          "$findings_file"
  check_xcode_derived_data      "$findings_file"
  check_coresimulator_caches    "$findings_file"
  check_coresimulator_devices   "$findings_file"
  check_ios_devicesupport       "$findings_file"

  local ai_model=""
  if $use_ai; then
    # Resolve provider/model up front so the report header can name the model.
    ai_resolve && ai_model="$AI_MODEL_RESOLVED" || true
    # On failure (no key, declined, network error) ai_file stays empty and the
    # report renders without an AI section — the standard scan still stands.
    run_ai_analysis "$findings_file" "$ai_file" "$assume_yes" || true
  fi

  local out include_flow flow_rows stamp
  stamp="$(filename_now)"
  include_flow="true"
  $quick && include_flow="false"

  # Compute the flow-type rows once and share with both renderers (avoids
  # walking $HOME twice when --html is also requested).
  flow_rows=""
  [[ "$include_flow" == "true" ]] && flow_rows="$(find_flow_type_files)"

  out="$SCANS_DIR/$stamp.md"
  render_report "$findings_file" "$out" "$include_flow" "$ai_file" "$ai_model" "$flow_rows"
  info "Report saved: $(tildify "$out")"

  if $want_html; then
    local html_out="$SCANS_DIR/$stamp.html"
    render_html "$findings_file" "$ai_file" "$ai_model" "$html_out" "$include_flow" "$flow_rows"
    info "HTML report saved: $(tildify "$html_out")"
    # When driven by `serve`, drop a machine-readable sidecar so the local
    # server has an authoritative whitelist of finding paths for the delete UI.
    [[ -n "${DISKSAGE_SERVE:-}" ]] && cp "$findings_file" "$SCANS_DIR/$stamp.findings.tsv"
    printf '\n%sNext:%s open "%s"\n' "$C_BOLD" "$C_RESET" "$(tildify "$html_out")"
  else
    printf '\n%sNext:%s open "%s"\n' "$C_BOLD" "$C_RESET" "$(tildify "$out")"
  fi
}

cmd_serve() {
  ensure_dirs
  resolve_lang
  local use_ai=false quick=false assume_yes=false port="${DISKSAGE_PORT:-8765}"
  while (( $# > 0 )); do
    case "$1" in
      --ai)        use_ai=true ;;
      --quick)     quick=true ;;
      -y|--yes)    assume_yes=true ;;
      -p|--port)   shift; port="${1:-8765}" ;;
      --port=*)    port="${1#--port=}" ;;
      -h|--help)   cmd_help serve; return 0 ;;
      *)           warn "serve: ignoring unknown argument '$1'" ;;
    esac
    shift
  done

  command -v python3 >/dev/null 2>&1 || die "serve requires python3."

  # These flags drive both the initial scan and every browser-triggered re-scan.
  local -a scan_flags=(scan --html)
  $quick && scan_flags+=(--quick)
  if $use_ai; then
    if $assume_yes; then
      scan_flags+=(--ai --yes)
    else
      warn "serve runs non-interactively; --ai needs --yes to confirm sending."
      warn "Continuing WITHOUT AI. Re-run as: disksage serve --ai --yes"
    fi
  fi

  # Absolute path to this script, so the server can re-run scans on demand.
  local self
  self="$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd)/$(basename "$0")"
  [[ -x "$self" ]] || self="$(command -v disksage 2>/dev/null || echo "$self")"

  info "Running initial scan…"
  DISKSAGE_SERVE=1 "$self" "${scan_flags[@]}" >&2 || warn "initial scan reported an issue (continuing)."

  info "Serving DiskSage at http://127.0.0.1:$port  (Ctrl-C to stop)"

  SELF="$self" SERVE_SCANS_DIR="$SCANS_DIR" PORT="$port" SERVE_LANG="$DS_LANG" \
  SERVE_HOME="$HOME" SCAN_FLAGS="${scan_flags[*]}" python3 <<'PYEOF'
import os, glob, html, json, http.server, socketserver, subprocess, shlex, threading, webbrowser, urllib.parse

scans_dir = os.environ["SERVE_SCANS_DIR"]
self_bin = os.environ["SELF"]
home = os.environ["SERVE_HOME"]
port = int(os.environ.get("PORT", "8765"))
ja = os.environ.get("SERVE_LANG", "en") == "ja"
scan_flags = shlex.split(os.environ.get("SCAN_FLAGS", "scan --html"))
# Re-scans (and the delete-then-rescan) must also emit the findings sidecar.
scan_env = {**os.environ, "DISKSAGE_SERVE": "1"}

# Only these patterns are offered for one-click Trash: their finding path IS the
# thing to delete and is safe/recoverable. Excluded on purpose: electron_cache
# (path is the app dir, not its cache), docker_raw (risky while Docker runs),
# node_modules_aggregate (path is ~/Development — would nuke everything),
# apfs_snapshots and vm_swap (need tmutil / reboot, not Trash).
DELETABLE = {"iphone_backup", "ollama_models", "xcode_derived_data",
             "coresimulator_caches", "coresimulator_devices", "ios_devicesupport"}

rescan_label = "再スキャン" if ja else "Re-scan"
scanning_label = "スキャン中…" if ja else "Scanning…"
empty_msg = ("まだレポートがありません。「再スキャン」を押してください。"
             if ja else "No report yet. Click Re-scan.")

def esc(s):
    return html.escape(str(s), quote=True)

def human(n):
    try:
        n = float(n)
    except (TypeError, ValueError):
        return "0 B"
    u = ("B", "KB", "MB", "GB", "TB", "PB")
    i = 0
    while n >= 1024 and i < len(u) - 1:
        n /= 1024
        i += 1
    return ("%d %s" % (int(n), u[i])) if i == 0 else ("%.1f %s" % (n, u[i]))

def tildify(p):
    if p == home:
        return "~"
    if p.startswith(home + "/"):
        return "~" + p[len(home):]
    return p

def newest(pat):
    files = glob.glob(os.path.join(scans_dir, pat))
    return max(files, key=os.path.getmtime) if files else None

def read_findings():
    f = newest("*.findings.tsv")
    out = []
    if not f:
        return out
    with open(f, encoding="utf-8") as h:
        for line in h:
            line = line.rstrip("\n")
            if not line:
                continue
            p = line.split("\t")
            if len(p) < 6:
                continue
            out.append({"sev": p[0], "pid": p[1], "path": p[2], "size": p[3], "desc": p[4]})
    return out

def deletable():
    # Whitelist: deletable pattern, under $HOME, and still present on disk.
    return [fi for fi in read_findings()
            if fi["pid"] in DELETABLE
            and fi["path"].startswith(home + "/")
            and os.path.exists(fi["path"])]

def to_trash(paths):
    # Move to the macOS Trash via Finder (recoverable). Never rm.
    items = ", ".join('POSIX file "%s"' % p.replace("\\", "\\\\").replace('"', '\\"')
                      for p in paths)
    subprocess.run(["osascript", "-e",
