# Look up a raw format string for (lang, key). Prints it (no newline); returns
# non-zero if the key is absent for that language.
t_lookup() {
  local lang="$1" key="$2" cat line
  case "$lang" in
    ja) cat="$CATALOG_JA" ;;
    *)  cat="$CATALOG_EN" ;;
  esac
  while IFS= read -r line; do
    case "$line" in
      "$key="*) printf '%s' "${line#*=}"; return 0 ;;
    esac
  done <<EOF
$cat
EOF
  return 1
}

# Translate: t <key> [printf-args...]. Falls back to English, then the key.
t() {
  local key="$1"; shift
  local fmt
  fmt="$(t_lookup "$DS_LANG" "$key")" || fmt="$(t_lookup en "$key")" || fmt="$key"
  # shellcheck disable=SC2059
  printf "$fmt" "$@"
}

# Resolve report language from DISKSAGE_LANG, else the system locale.
resolve_lang() { DS_LANG="$(ai_lang)"; }

# ───────────────────────────────────────────────────────────────
# Pattern checks (macOS-focused for v0.1)
# ───────────────────────────────────────────────────────────────

# 1. APFS local snapshots (Time Machine keeps deleted files alive)
check_apfs_snapshots() {
  local f="$1"
  [[ "$OS" == "Darwin" ]] || return 0
  local snaps
  snaps=$(tmutil listlocalsnapshots / 2>/dev/null | grep -Ec 'com\.apple\.TimeMachine' || true)
  [[ -z "$snaps" ]] && snaps=0
  if (( snaps > 3 )); then
    add_finding "$f" "apfs_snapshots" "/" 0 "high" \
      "$(t desc_apfs "$snaps")" \
      "$(t act_apfs)"
  fi
}

# 2. iPhone backups — Apple's official location + common third-party apps.
#    A backup without Manifest.db cannot be restored — flagged high.
check_iphone_backup() {
  local f="$1"
  local location size has_manifest
  local locations=(
    "Apple|$HOME/Library/Application Support/MobileSync/Backup"
    "iMobie|$HOME/Library/Application Support/iMobie"
    "AnyTrans|$HOME/Library/Application Support/AnyTrans"
    "3uTools|$HOME/Library/Application Support/3uTools"
    "DearMob|$HOME/Library/Application Support/DearMob"
    "iMazing|$HOME/Library/Application Support/iMazing"
  )
  for location in "${locations[@]}"; do
    local vendor="${location%%|*}"
    local vdir="${location#*|}"
    [[ -d "$vdir" ]] || continue
    size=$(dir_size_bytes "$vdir")
    # Ignore < 1 GB (likely empty shells or cache-only installs)
    (( size > 1024 * 1024 * 1024 )) || continue
    has_manifest=false
    while IFS= read -r -d '' _; do has_manifest=true; break; done \
      < <(find "$vdir" -name Manifest.db -print0 2>/dev/null)
    if $has_manifest; then
      add_finding "$f" "iphone_backup" "$vdir" "$size" "medium" \
        "$(t desc_iphone_ok "$vendor" "$(human_size "$size")")" \
        "$(t act_iphone_ok "$vendor")"
    else
      add_finding "$f" "iphone_backup" "$vdir" "$size" "high" \
        "$(t desc_iphone_broken "$vendor" "$(human_size "$size")")" \
        "$(t act_iphone_broken)"
    fi
  done
}

# 3. Docker.raw (Docker Desktop VM disk; never shrinks automatically)
check_docker_raw() {
  local f="$1"
  local candidates=(
    "$HOME/Library/Containers/com.docker.docker/Data/vms/0/data/Docker.raw"
    "$HOME/Library/Containers/com.docker.docker/Data/vms/0/Docker.raw"
    "$HOME/Library/Group Containers/group.com.docker/DockerDesktop/vms/0/data/Docker.raw"
  )
  local c size
  for c in "${candidates[@]}"; do
    [[ -f "$c" ]] || continue
    size=$(file_size_bytes "$c")
    if (( size > 10 * 1024 * 1024 * 1024 )); then
      add_finding "$f" "docker_raw" "$c" "$size" "medium" \
        "$(t desc_docker "$(human_size "$size")")" \
        "$(t act_docker)"
    fi
  done
}

# 4. Ollama local model blobs
check_ollama_models() {
  local f="$1"
  local mdir="$HOME/.ollama/models"
  [[ -d "$mdir" ]] || return 0
  local size
  size=$(dir_size_bytes "$mdir")
  if (( size > 10 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "ollama_models" "$mdir" "$size" "medium" \
      "$(t desc_ollama "$(human_size "$size")" "$(tildify "$mdir")")" \
      "$(t act_ollama)"
  fi
}

# 5. node_modules aggregate under ~/Development (sum across projects)
check_node_modules_aggregate() {
  local f="$1"
  local devroot="$HOME/Development"
  [[ -d "$devroot" ]] || return 0
  local total=0 sz nm
  while IFS= read -r nm; do
    sz=$(dir_size_bytes "$nm")
    total=$(( total + sz ))
  done < <(find "$devroot" -type d -name node_modules -prune -print 2>/dev/null)
  if (( total > 10 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "node_modules_aggregate" "$devroot" "$total" "low" \
      "$(t desc_node "$(tildify "$devroot")" "$(human_size "$total")")" \
      "$(t act_node)"
  fi
}

# 6. macOS VM swap + sleepimage (rebuilt on reboot)
check_vm_swap() {
  local f="$1"
  [[ "$OS" == "Darwin" ]] || return 0
  local vmdir="/private/var/vm"
  [[ -d "$vmdir" ]] || return 0
  local total=0 swap sz
  for swap in "$vmdir"/swapfile* "$vmdir"/sleepimage; do
    [[ -f "$swap" ]] || continue
    sz=$(file_size_bytes "$swap")
    total=$(( total + sz ))
  done
  if (( total > 5 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "vm_swap" "$vmdir" "$total" "medium" \
      "$(t desc_swap "$(human_size "$total")")" \
      "$(t act_swap)"
  fi
}

# 7. Electron / browser-style caches inside ~/Library/Application Support
check_electron_cache() {
  local f="$1"
  local appsup="$HOME/Library/Application Support"
  [[ -d "$appsup" ]] || return 0
  local d app_total cache cdir sz appname
  while IFS= read -r d; do
    [[ -d "$d" ]] || continue
    app_total=0
    for cache in "Cache" "Code Cache" "GPUCache"; do
      cdir="$d/$cache"
      [[ -d "$cdir" ]] || continue
      sz=$(dir_size_bytes "$cdir")
      app_total=$(( app_total + sz ))
    done
    if (( app_total > 500 * 1024 * 1024 )); then
      appname="$(basename "$d")"
      add_finding "$f" "electron_cache" "$d" "$app_total" "safe" \
        "$(t desc_electron "$appname" "$(human_size "$app_total")")" \
        "$(t act_electron "$appname" "$(tildify "$d")")"
    fi
  done < <(find "$appsup" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
}

# 8. Xcode DerivedData (safe to wipe; regenerates on next build)
check_xcode_derived_data() {
  local f="$1"
  local dd="$HOME/Library/Developer/Xcode/DerivedData"
  [[ -d "$dd" ]] || return 0
  local size
  size=$(dir_size_bytes "$dd")
  if (( size > 5 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "xcode_derived_data" "$dd" "$size" "safe" \
      "$(t desc_xcode "$(human_size "$size")")" \
      "$(t act_xcode)"
  fi
}

# 9. Xcode Simulator caches (regenerated on demand)
check_coresimulator_caches() {
  local f="$1"
  [[ "$OS" == "Darwin" ]] || return 0
  local dir="$HOME/Library/Developer/CoreSimulator/Caches"
  [[ -d "$dir" ]] || return 0
  local size
  size=$(dir_size_bytes "$dir")
  if (( size > 1 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "coresimulator_caches" "$dir" "$size" "safe" \
      "$(t desc_simcache "$(human_size "$size")")" \
      "$(t act_simcache)"
  fi
}

# 10. Xcode Simulator devices (old/unused simulators hold disk; deleting wipes state)
check_coresimulator_devices() {
  local f="$1"
  [[ "$OS" == "Darwin" ]] || return 0
  local dir="$HOME/Library/Developer/CoreSimulator/Devices"
  [[ -d "$dir" ]] || return 0
  local size
  size=$(dir_size_bytes "$dir")
  if (( size > 5 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "coresimulator_devices" "$dir" "$size" "medium" \
      "$(t desc_simdevices "$(human_size "$size")")" \
      "$(t act_simdevices)"
  fi
}

# 11. Xcode iOS DeviceSupport (debug symbols, re-downloaded on device connect)
check_ios_devicesupport() {
  local f="$1"
  [[ "$OS" == "Darwin" ]] || return 0
  local dir="$HOME/Library/Developer/Xcode/iOS DeviceSupport"
  [[ -d "$dir" ]] || return 0
  local size
  size=$(dir_size_bytes "$dir")
  if (( size > 3 * 1024 * 1024 * 1024 )); then
    add_finding "$f" "ios_devicesupport" "$dir" "$size" "safe" \
      "$(t desc_devicesupport "$(human_size "$size")")" \
      "$(t act_devicesupport)"
  fi
}

# 12. Flow-type: files > 500 MB modified in the last 30 days.
#    Returns top 20 rows, "size_bytes<TAB>path".
find_flow_type_files() {
  find "$HOME" -type f -size +500M -mtime -30 -print 2>/dev/null \
    | while IFS= read -r fpath; do
        printf '%s\t%s\n' "$(file_size_bytes "$fpath")" "$fpath"
      done \
    | sort -rn \
    | head -20
}

# ───────────────────────────────────────────────────────────────
# Report rendering
# ───────────────────────────────────────────────────────────────

render_findings_section() {
  local findings_file="$1"
  local severity="$2"
  local rows count phrase
  rows=$(awk -F'\t' -v s="$severity" '$1==s' "$findings_file" 2>/dev/null || true)
  [[ -z "$rows" ]] && return 0
  count=$(printf '%s\n' "$rows" | grep -c .)
  if (( count == 1 )); then phrase="$(t item "$count")"; else phrase="$(t items "$count")"; fi
  echo
  echo "### $(t "sev_$severity") ($phrase)"
  printf '%s\n' "$rows" | sort -t$'\t' -k4,4 -nr \
    | while IFS=$'\t' read -r _sev _pid path size desc action; do
        echo "- **$desc**"
        [[ -n "$path" && "$path" != "/" ]] && echo "  - $(t lbl_path): \`$(tildify "$path")\`"
        (( size > 0 )) && echo "  - $(t lbl_size): $(human_size "$size")"
        [[ -n "$action" ]] && echo "  - $(t lbl_action): $action"
      done
}

render_flow_type_section() {
  local rows="$1"   # pre-computed by cmd_scan (avoids walking $HOME twice)
  echo
  echo "## $(t h_flow)"
  if [[ -z "$rows" ]]; then
    echo
    echo "$(t flow_none)"
    return
  fi
  echo
  echo '```'
  printf '%s\n' "$rows" | while IFS=$'\t' read -r sz path; do
    printf '%-10s  %s\n' "$(human_size "$sz")" "$(tildify "$path")"
  done
  echo '```'
}

render_disk_usage() {
  echo "## $(t h_disk)"
  echo
  echo '```'
  df -h 2>/dev/null | awk 'NR==1 || $1 ~ /^\/dev\//'
  echo '```'
}

render_report() {
  local findings_file="$1"
  local out="$2"
  local include_flow="${3:-true}"
  local ai_file="${4:-}"
  local ai_model="${5:-}"
  local flow_rows="${6:-}"
  local total_findings
  total_findings=$(wc -l < "$findings_file" | tr -d ' ')
  {
    echo "# $(t title)"
    echo
