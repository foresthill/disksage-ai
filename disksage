# ───────────────────────────────────────────────────────────────
# AI mode (Phase 2) — Claude API contextual judgment
#
# Privacy contract: only file NAMES, PATHS, SIZES and DiskSage's own
# heuristic descriptions are ever sent. File CONTENTS are never read or
# transmitted. The user sees the exact metadata and confirms before
# anything leaves the machine. BYOK: the user's own ANTHROPIC_API_KEY.
# ───────────────────────────────────────────────────────────────

# Resolve which provider / endpoint / key / model to use for --ai, into the
# AI_* globals. Precedence: DISKSAGE_AI_PROVIDER (explicit) > ANTHROPIC_API_KEY
# > OPENROUTER_API_KEY. Returns non-zero (and leaves globals empty) if no
# usable key is available.
ai_resolve() {
  AI_PROVIDER=""; AI_URL=""; AI_KEY=""; AI_AUTH=""; AI_VERSION_HDR=""; AI_MODEL_RESOLVED=""
  local pref="${DISKSAGE_AI_PROVIDER:-}"

  if [[ "$pref" == "anthropic" || ( -z "$pref" && -n "${ANTHROPIC_API_KEY:-}" ) ]]; then
    [[ -n "${ANTHROPIC_API_KEY:-}" ]] || return 1
    AI_PROVIDER="anthropic"
    AI_URL="${DISKSAGE_AI_BASE_URL:-$AI_ANTHROPIC_URL}"
    AI_KEY="$ANTHROPIC_API_KEY"
    AI_AUTH="x-api-key"
    AI_VERSION_HDR="$AI_API_VERSION"
    AI_MODEL_RESOLVED="${DISKSAGE_MODEL:-$AI_MODEL_ANTHROPIC}"
  elif [[ "$pref" == "openrouter" || ( -z "$pref" && -n "${OPENROUTER_API_KEY:-}" ) ]]; then
    [[ -n "${OPENROUTER_API_KEY:-}" ]] || return 1
    AI_PROVIDER="openrouter"
    AI_URL="${DISKSAGE_AI_BASE_URL:-$AI_OPENROUTER_URL}"
    AI_KEY="$OPENROUTER_API_KEY"
    AI_AUTH="bearer"
    AI_VERSION_HDR=""   # OpenRouter does not require anthropic-version
    AI_MODEL_RESOLVED="${DISKSAGE_MODEL:-$AI_MODEL_OPENROUTER}"
  else
    return 1
  fi
  return 0
}

# Resolve the language for AI 'reasoning' text. DISKSAGE_LANG wins; otherwise
# derive from the system locale ($LC_ALL/$LANG); falls back to "en". Returns a
# lowercase 2-letter-ish code (e.g. ja, en, zh).
ai_lang() {
  local l="${DISKSAGE_LANG:-}"
  [[ -z "$l" ]] && l="${LC_ALL:-${LANG:-}}"
  l="${l%%.*}"   # strip ".UTF-8"
  l="${l%%_*}"   # strip "_JP"
  l="$(printf '%s' "$l" | tr '[:upper:]' '[:lower:]')"
  [[ -z "$l" ]] && l="en"
  printf '%s' "$l"
}

# Mask the findings file before it leaves the machine. Emits a TSV in the
# same 6-column shape (so build_ai_request/preview consume it unchanged):
#   - paths: $HOME → ~ (drops username); known tool/vendor/system path
#     components are kept; any other user-specific component is anonymized to
#     <dirN> (stable within a run).
#   - descriptions: any literal $HOME is collapsed to ~.
# Line order (and therefore index) is preserved 1:1 with the original, so the
# report can still join real paths back by index.
ai_mask_findings() {
  local findings_file="$1"
  FINDINGS_FILE="$findings_file" HOMEDIR="$HOME" python3 <<'PYEOF'
import os, re

findings_file = os.environ["FINDINGS_FILE"]
home = os.environ["HOMEDIR"]

# Known-safe path components: tool dirs, system structure, and backup-vendor
# names. These carry no personal info and are what lets the model judge
# accurately. Everything else is treated as user-specific and anonymized.
SAFE = {
    "~", "library", "application support", "application scripts",
    "containers", "group containers", "caches", "cache",
    "code cache", "gpucache", "developer", "xcode", "deriveddata",
    "data", "vms", "private", "var", "vm", "mobilesync", "backup",
    ".ollama", "models", "blobs", "manifests", ".disksage",
    "development", "documents", "downloads", "desktop", "movies",
    "music", "pictures", "public", "node_modules", "logs", "tmp",
    "com.docker.docker", "group.com.docker", "dockerdesktop",
    "imobie", "anytrans", "3utools", "dearmob", "imazing",
}
FILE_OK = re.compile(r"^(swapfile\d*|sleepimage|docker\.raw)$", re.IGNORECASE)

def tildify(p):
    if p == home:
        return "~"
    if p.startswith(home + "/"):
        return "~" + p[len(home):]
    return p

_alias = {}
def anon(name):
    key = name.lower()
    if key not in _alias:
        _alias[key] = "<dir%d>" % (len(_alias) + 1)
    return _alias[key]

def mask_component(c):
    if c == "":
        return c
    if c.lower() in SAFE or c.isdigit() or FILE_OK.match(c):
        return c
    return anon(c)

def mask_path(p):
    if not p:
        return p
    t = tildify(p)
    if t in ("/", "~"):
        return t
    return "/".join(mask_component(c) for c in t.split("/"))

with open(findings_file) as f:
    for line in f:
        line = line.rstrip("\n")
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 6:
            continue
        severity, pattern_id, path, size_bytes, description, action = parts[:6]
        masked_desc = description.replace(home, "~").replace("\t", " ")
        print("\t".join([severity, pattern_id, mask_path(path),
                         size_bytes, masked_desc, action]))
PYEOF
}

