    "ru": "Russian", "nl": "Dutch", "tr": "Turkish", "ar": "Arabic",
}
if lang_code and lang_code != "en":
    lang_name = LANGS.get(lang_code, "the language with ISO code '%s'" % lang_code)
    system += (
        " Write every \"reasoning\" value in %s. Keep the JSON keys and the "
